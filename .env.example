# --- Admin credentials ---
ADMIN_USERNAME=admin

# For development you can use a plain password:
ADMIN_PASSWORD=admin123

# For production, DO NOT ship a plain password. Generate a hash and use this instead:
#   npm run hash-password
# Then set ADMIN_PASSWORD_HASH here and remove ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH=scrypt$...

# --- Sessions ---
# Change to a long random string in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=replace-with-a-long-random-string

# --- Site ---
# Public URL where the site is reachable. Used for canonical links, sitemap, OpenGraph.
SITE_URL=http://localhost:3000

# --- Storage ---
# Directory where services.json / orders.json live.
# Defaults to ./data. Point at a persistent volume in production.
# DATA_DIR=/var/lib/saftey
